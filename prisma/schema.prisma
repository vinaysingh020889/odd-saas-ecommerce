  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, scope, usedAt])
  @@index([userMembershipId, benefitId])
  @@index([userId, usedAt])
}

model MembershipStatusHistory {
  id                String                @id @default(cuid())
  tenantId          String
