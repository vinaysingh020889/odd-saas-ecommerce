  plan          MembershipPlan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  benefit       MembershipBenefit?     @relation(fields: [benefitId], references: [id], onDelete: SetNull)

  @@index([tenantId, scope, active])
  @@index([planId])
  @@index([benefitId])
}

model UserMembership {
  id                 String                @id @default(cuid())
  tenantId           String
  userId             String
  planId             String
  status             UserMembershipStatus  @default(ACTIVE)
  startsAt           DateTime
  expiresAt          DateTime
  activatedByOrderRef String?
  mockPaymentReference String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               MembershipPlan        @relation(fields: [planId], references: [id], onDelete: Restrict)
  usages             MembershipBenefitUsage[]
  statusHistory      MembershipStatusHistory[]
  requests           MembershipRequest[]

  @@index([tenantId, status])
  @@index([userId, status])
  @@index([planId, status])
}

model MembershipRequest {
  id                String          @id @default(cuid())
  tenantId          String
  userId            String
  userMembershipId  String?
  currentPlanId     String?
  requestedPlanId   String?
  requestType       String
  status            String          @default("submitted")
  customerNote      String?
  adminDecisionNote String?
  reviewedById      String?
  reviewedAt        DateTime?
  closedAt          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User            @relation("MembershipRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  userMembership    UserMembership? @relation(fields: [userMembershipId], references: [id], onDelete: SetNull)
  currentPlan       MembershipPlan? @relation("MembershipRequestCurrentPlan", fields: [currentPlanId], references: [id], onDelete: SetNull)
  requestedPlan     MembershipPlan? @relation("MembershipRequestRequestedPlan", fields: [requestedPlanId], references: [id], onDelete: SetNull)
  reviewedBy        User?           @relation("MembershipRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([tenantId, status, requestType])
  @@index([userId, createdAt])
  @@index([userMembershipId, createdAt])
}

model MembershipBenefitUsage {
  id                String                 @id @default(cuid())
  tenantId          String
  userMembershipId  String
  benefitId         String
  userId            String
  scope             MembershipBenefitScope
