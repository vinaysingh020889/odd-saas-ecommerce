  requestedMembershipRequests MembershipRequest[] @relation("MembershipRequestRequestedPlan")

  @@unique([tenantId, slug])
  @@index([tenantId, status, sortOrder])
}

model MembershipBenefit {
  id           String                 @id @default(cuid())
  tenantId     String
  planId       String
  title        String
  description  String?
  type         MembershipBenefitType
  scope        MembershipBenefitScope
  valueDecimal Decimal?               @db.Decimal(12, 2)
  valueText    String?
  usageLimit   Int?
  usagePeriod  MembershipUsagePeriod?
  active       Boolean                @default(true)
  validFrom    DateTime?
  validUntil   DateTime?
  customerVisible Boolean             @default(true)
  internalNote String?
  sortOrder    Int                    @default(0)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan         MembershipPlan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  rules        MembershipRule[]
  usages       MembershipBenefitUsage[]

  @@index([tenantId, scope, active])
  @@index([planId, sortOrder])
}

model MembershipRule {
  id            String                 @id @default(cuid())
  tenantId      String
  planId        String
  benefitId     String?
  scope         MembershipBenefitScope
  ruleKey       String
  ruleValueJson Json
  valueDecimal  Decimal?               @db.Decimal(12, 2)
  usageLimit    Int?
  usagePeriod   MembershipUsagePeriod?
  minAmount     Decimal?               @db.Decimal(12, 2)
  validFrom     DateTime?
  validUntil    DateTime?
  priority      Int                    @default(0)
