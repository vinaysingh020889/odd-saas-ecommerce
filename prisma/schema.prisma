model MembershipPlan {
  id          String               @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?
  price       Decimal              @db.Decimal(12, 2)
  currency    String               @default("INR")
  durationDays Int
  status      MembershipPlanStatus @default(ACTIVE)
  sortOrder   Int                  @default(0)
