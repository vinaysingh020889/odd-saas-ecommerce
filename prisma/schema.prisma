generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum HeroSlideLinkType {
  CUSTOM
  PRODUCT
  SERVICE
  FESTIVAL
  OFFER
  MEMBERSHIP
  ASTHI
  KUNDLI
}

enum HeroSlideTheme {
  DARK_OVERLAY
  LIGHT_OVERLAY
  CREAM_CARD
  SAFFRON_GOLD
}

enum HeroSlideTextAlign {
  LEFT
  CENTER
  RIGHT
}

enum HeroSlideOverlay {
  NONE
  LIGHT
  MEDIUM
  STRONG
}
model Tenant {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  domain    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  users     User[]
  roles     Role[]
  userRoles UserRole[]
  auditLogs AuditLog[]
  categories Category[]
  products   Product[]
  carts      Cart[]
  orders     Order[]
  inventoryMovements InventoryLedger[]
  orderActivities OrderActivity[]
  kitComponents KitComponent[]
  paymentAttempts PaymentAttempt[]
  paymentEvents PaymentEvent[]
  membershipSubscriptions MembershipSubscription[]
  asthiLocations AsthiLocation[]
  asthiPackages AsthiPackage[]
  asthiAddOns AsthiAddOn[]
  asthiApplications AsthiApplication[]
  asthiDocuments AsthiDocument[]
  asthiActivities AsthiActivity[]
  asthiStatusHistories AsthiStatusHistory[]
  productMedia ProductMedia[]
  productReviews ProductReview[]
  productSpecs ProductSpec[]
  productFaqs ProductFaq[]
  productContentBlocks ProductContentBlock[]
  wishlistItems WishlistItem[]
  festivalCampaigns FestivalCampaign[]
  festivalCampaignProducts FestivalCampaignProduct[]
  festivalCampaignCategories FestivalCampaignCategory[]
  festivalCampaignServices FestivalCampaignService[]
  promotionPlacements PromotionPlacement[]
  heroSlides HeroSlide[]
  serviceablePincodes ServiceablePincode[]
  offerRules OfferRule[]
  offerTargets OfferTarget[]
  offerRedemptions OfferRedemption[]
  membershipPlans MembershipPlan[]
  membershipBenefits MembershipBenefit[]
  membershipRules MembershipRule[]
  userMemberships UserMembership[]
  membershipRequests MembershipRequest[]
  membershipBenefitUsages MembershipBenefitUsage[]
  membershipStatusHistories MembershipStatusHistory[]
  kundliPackages KundliPackage[]
  kundliOrders KundliOrder[]
  kundliDocuments KundliDocument[]
  kundliStatusHistories KundliStatusHistory[]
  tags Tag[]
  tagAliases TagAlias[]
  tagRelations TagRelation[]
  searchQueryLogs SearchQueryLog[]
  customerAddresses CustomerAddress[]
  orderRequests OrderRequest[]
  serviceBookings ServiceBooking[]
  serviceBookingActivities ServiceBookingActivity[]
  rescheduleRequests RescheduleRequest[]
  rescheduleRequestActivities RescheduleRequestActivity[]
  checklistTemplates ChecklistTemplate[]
  checklistTemplateItems ChecklistTemplateItem[]
  checklistInstances ChecklistInstance[]
  checklistInstanceItems ChecklistInstanceItem[]
  checklistActivities ChecklistActivity[]
  serviceCapacityRules ServiceCapacityRule[]
  serviceCapacitySlots ServiceCapacitySlot[]
  serviceCapacityLedgers ServiceCapacityLedger[]
  assignments Assignment[]
  operationalDocuments OperationalDocument[]
  documentActivities DocumentActivity[]
  customerNotes CustomerNote[]
  customerEvents CustomerEvent[]
  customerInterestProfiles CustomerInterestProfile[]
  anonymousInterestProfiles AnonymousInterestProfile[]
}

model Role {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  key       String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users     UserRole[]

  @@unique([tenantId, key])
}

model User {
  id            String     @id @default(cuid())
  tenantId      String
  email         String?    @unique
  phone         String?    @unique
  name          String?
  passwordHash  String?
  status        String     @default("ACTIVE")
  verifiedEmail Boolean    @default(false)
  verifiedPhone Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles         UserRole[]
  carts         Cart[]
  orders        Order[]
  inventoryMovements InventoryLedger[]
  orderActivities OrderActivity[]
  membershipSubscriptions MembershipSubscription[]
  asthiApplications AsthiApplication[]
  asthiUploadedDocuments AsthiDocument[] @relation("AsthiDocumentUploader")
  asthiReviewedDocuments AsthiDocument[] @relation("AsthiDocumentReviewer")
  asthiActivities AsthiActivity[]
  productReviews ProductReview[]
  wishlistItems WishlistItem[]
  offerRedemptions OfferRedemption[]
  userMemberships UserMembership[]
  membershipBenefitUsages MembershipBenefitUsage[]
  membershipRequests MembershipRequest[] @relation("MembershipRequestUser")
  reviewedMembershipRequests MembershipRequest[] @relation("MembershipRequestReviewer")
  kundliOrders KundliOrder[]
  searchQueryLogs SearchQueryLog[]
  customerAddresses CustomerAddress[]
  createdOrderRequests OrderRequest[] @relation("OrderRequestCreator")
  reviewedOrderRequests OrderRequest[] @relation("OrderRequestReviewer")
  serviceCapacityLedgers ServiceCapacityLedger[]
  assignedAssignments Assignment[] @relation("AssignmentAssignedUser")
  createdAssignments Assignment[] @relation("AssignmentCreator")
  updatedAssignments Assignment[] @relation("AssignmentUpdater")
  uploadedOperationalDocuments OperationalDocument[] @relation("OperationalDocumentUploader")
  reviewedOperationalDocuments OperationalDocument[] @relation("OperationalDocumentReviewer")
  documentActivities DocumentActivity[]
  customerNotes CustomerNote[] @relation("CustomerNotes")
  createdCustomerNotes CustomerNote[] @relation("CustomerNoteCreator")
  customerEvents CustomerEvent[]
  customerInterestProfile CustomerInterestProfile?
  serviceBookings ServiceBooking[]
  serviceBookingActivities ServiceBookingActivity[]
  createdRescheduleRequests RescheduleRequest[] @relation("RescheduleRequestCreator")
  reviewedRescheduleRequests RescheduleRequest[] @relation("RescheduleRequestReviewer")
  rescheduleRequestActivities RescheduleRequestActivity[]
  createdChecklistInstances ChecklistInstance[] @relation("ChecklistInstanceCreator")
  assignedChecklistItems ChecklistInstanceItem[] @relation("ChecklistItemAssignee")
  completedChecklistItems ChecklistInstanceItem[] @relation("ChecklistItemCompleter")
  checklistActivities ChecklistActivity[]

  @@index([tenantId])
}

model CustomerEvent {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String?
  anonymousId  String?
  sessionId    String?
  eventType    String
  entityType   String?
  entityId     String?
  entitySlug   String?
  metadataJson Json?
  sourcePath   String?
  referrer     String?
  userAgent    String?
  ipHash       String?
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, eventType, createdAt])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, anonymousId, createdAt])
  @@index([userId, createdAt])
}

model CustomerInterestProfile {
  id               String   @id @default(cuid())
  tenantId         String
  userId           String   @unique
  topTagsJson      Json?
  topCategoriesJson Json?
  topProductsJson  Json?
  topServicesJson  Json?
  topFestivalsJson Json?
  searchTermsJson  Json?
  lastActivityAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, lastActivityAt])
}

model AnonymousInterestProfile {
  id               String   @id @default(cuid())
  tenantId         String
  anonymousId      String
  topTagsJson      Json?
  topCategoriesJson Json?
  topProductsJson  Json?
  topServicesJson  Json?
  topFestivalsJson Json?
  searchTermsJson  Json?
  lastActivityAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, anonymousId])
  @@index([tenantId, lastActivityAt])
}

model CustomerNote {
  id          String   @id @default(cuid())
  tenantId    String
  customerId  String
  createdById String
  note        String
  category    String   @default("GENERAL")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer    User     @relation("CustomerNotes", fields: [customerId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("CustomerNoteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId, createdAt])
  @@index([createdById, createdAt])
}

model CustomerAddress {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String   @default("India")
  pincode      String
  landmark     String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([userId, isDefault])
}

model UserRole {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  actorId   String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model OperationalDocument {
  id              String   @id @default(cuid())
  tenantId        String
  ownerType       String
  ownerId         String
  documentType    String
  title           String
  description     String?
  fileName        String?
  fileUrl         String?
  storageKey      String?
  mimeType        String?
  fileSize        Int?
  visibility      String   @default("INTERNAL_ONLY")
  status          String   @default("REQUESTED")
  rejectionReason String?
  uploadedById    String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy      User?    @relation("OperationalDocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  reviewedBy      User?    @relation("OperationalDocumentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  activities      DocumentActivity[]

  @@index([tenantId, ownerType, ownerId])
  @@index([tenantId, documentType, status])
  @@index([tenantId, visibility, status])
}

model DocumentActivity {
  id         String              @id @default(cuid())
  tenantId   String
  documentId String
  action     String
  actorId    String?
  note       String?
  createdAt  DateTime            @default(now())
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document   OperationalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  actor      User?               @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([documentId, createdAt])
}

model ChecklistTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  workType    String
  description String?
  status      String   @default("ACTIVE")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       ChecklistTemplateItem[]
  instances   ChecklistInstance[]

  @@unique([tenantId, workType, name])
  @@index([tenantId, workType, status, sortOrder])
}

model ChecklistTemplateItem {
  id                        String            @id @default(cuid())
  tenantId                  String
  templateId                String
  title                     String
  description               String?
  required                  Boolean           @default(true)
  defaultOwnerRole          String?
  customerVisibleMilestone  Boolean           @default(false)
  proofRequired             Boolean           @default(false)
  dueOffsetHours            Int?
  sortOrder                 Int               @default(0)
  status                    String            @default("ACTIVE")
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  tenant                    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template                  ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([tenantId, templateId, status, sortOrder])
}

model ChecklistInstance {
  id                   String                  @id @default(cuid())
  tenantId             String
  relatedType          String
  relatedId            String
  templateId           String?
  status               String                  @default("OPEN")
  progressPercent      Int                     @default(0)
  requiredPendingCount Int                     @default(0)
  overdueCount         Int                     @default(0)
  blockedCount         Int                     @default(0)
  createdById          String?
  createdBySystem      Boolean                 @default(true)
  overrideReason       String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  tenant               Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template             ChecklistTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy            User?                   @relation("ChecklistInstanceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  items                ChecklistInstanceItem[]
  activities           ChecklistActivity[]

  @@unique([tenantId, relatedType, relatedId, templateId])
  @@index([tenantId, relatedType, relatedId])
  @@index([tenantId, status, requiredPendingCount])
}

model ChecklistInstanceItem {
  id                       String            @id @default(cuid())
  tenantId                 String
  checklistInstanceId      String
  title                    String
  description              String?
  required                 Boolean           @default(true)
  status                   String            @default("pending")
  assignedUserId           String?
  assignedRole             String?
  dueAt                    DateTime?
  completedById            String?
  completedAt              DateTime?
  skippedReason            String?
  blockedReason            String?
  internalNote             String?
  customerVisibleNote      String?
  customerVisibleMilestone Boolean           @default(false)
  proofRequired            Boolean           @default(false)
  sortOrder                Int               @default(0)
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  tenant                   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  checklistInstance        ChecklistInstance @relation(fields: [checklistInstanceId], references: [id], onDelete: Cascade)
  assignedUser             User?             @relation("ChecklistItemAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  completedBy              User?             @relation("ChecklistItemCompleter", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([tenantId, status, dueAt])
  @@index([checklistInstanceId, sortOrder])
  @@index([assignedUserId, status])
}

model ChecklistActivity {
  id                  String            @id @default(cuid())
  tenantId            String
  checklistInstanceId String
  itemId              String?
  action              String
  actorId             String?
  note                String?
  metadataJson        Json?
  createdAt           DateTime          @default(now())
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  checklistInstance   ChecklistInstance @relation(fields: [checklistInstanceId], references: [id], onDelete: Cascade)
  actor               User?             @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([checklistInstanceId, createdAt])
}

model ServiceBooking {
  id                    String                   @id @default(cuid())
  tenantId              String
  userId                String
  serviceId             String
  variantId             String?
  slotId                String?
  capacityRuleId        String?
  bookingNo             String?                  @unique
  status                String                   @default("DRAFT")
  paymentStatus         String                   @default("NOT_STARTED")
  capacityStatus        String                   @default("MANUAL_REVIEW")
  queuePosition         Int?
  queueJoinedAt         DateTime?
  queueReason           String?
  queuePriority         Boolean                  @default(false)
  queuePriorityReason   String?
  queuePriorityAt       DateTime?
  queuePrioritizedById  String?
  quantity              Int                      @default(1)
  participantCount      Int                      @default(1)
  preferredDate         DateTime?
  preferredTime         String?
  locationText          String?
  customerName          String
  customerEmail         String
  customerPhone         String
  specialInstructions   String?
  internalNote          String?
  customerVisibleNote   String?
  totalAmount           Decimal                  @default(0) @db.Decimal(12, 2)
  currency              String                   @default("INR")
  mockPaymentReference  String?
  proofStatus           String                   @default("not_available")
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  tenant                Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service               Product                  @relation("ServiceBookingService", fields: [serviceId], references: [id], onDelete: Restrict)
  variant               ProductVariant?          @relation("ServiceBookingVariant", fields: [variantId], references: [id], onDelete: SetNull)
  slot                  ServiceCapacitySlot?      @relation(fields: [slotId], references: [id], onDelete: SetNull)
  capacityRule          ServiceCapacityRule?      @relation(fields: [capacityRuleId], references: [id], onDelete: SetNull)
  activities            ServiceBookingActivity[]
  rescheduleRequests    RescheduleRequest[]

  @@index([tenantId, status])
  @@index([tenantId, paymentStatus])
  @@index([userId, createdAt])
  @@index([serviceId, status])
  @@index([tenantId, serviceId, status, queuePriority, queueJoinedAt])
  @@index([capacityRuleId])
  @@index([slotId])
  @@index([bookingNo])
}

model ServiceBookingActivity {
  id              String         @id @default(cuid())
  tenantId        String
  serviceBookingId String
  actorId         String?
  type            String
  message         String
  customerVisible Boolean        @default(true)
  metadataJson    Json?
  createdAt       DateTime       @default(now())
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceBooking  ServiceBooking @relation(fields: [serviceBookingId], references: [id], onDelete: Cascade)
  actor           User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([serviceBookingId, createdAt])
}

model RescheduleRequest {
  id                    String                      @id @default(cuid())
  tenantId              String
  requestNo             String?                     @unique
  relatedType           String
  relatedId             String
  serviceBookingId      String?
  currentDate           DateTime?
  currentTime           String?
  currentSlotId         String?
  currentLocation       String?
  requestedDate         DateTime?
  requestedTime         String?
  requestedSlotId       String?
  requestedLocation     String?
  customerReason        String?
  adminDecision         String?
  adminNote             String?
  customerVisibleNote   String?
  status                String                      @default("submitted")
  capacityDecision      String?
  capacityReason        String?
  queuePosition         Int?
  requestedById         String?
  reviewedById          String?
  reviewedAt            DateTime?
  closedAt              DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  tenant                Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedBy           User?                       @relation("RescheduleRequestCreator", fields: [requestedById], references: [id], onDelete: SetNull)
  reviewedBy            User?                       @relation("RescheduleRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  serviceBooking        ServiceBooking?             @relation(fields: [serviceBookingId], references: [id], onDelete: Cascade)
  activities            RescheduleRequestActivity[]

  @@index([tenantId, status, relatedType])
  @@index([tenantId, serviceBookingId, status])
  @@index([relatedType, relatedId])
  @@index([requestedById, createdAt])
}

model RescheduleRequestActivity {
  id                  String            @id @default(cuid())
  tenantId            String
  rescheduleRequestId String
  actorId             String?
  action              String
  note                String?
  createdAt           DateTime          @default(now())
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rescheduleRequest   RescheduleRequest @relation(fields: [rescheduleRequestId], references: [id], onDelete: Cascade)
  actor               User?             @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([rescheduleRequestId, createdAt])
}

model ServiceCapacitySlot {
  id                String   @id @default(cuid())
  tenantId          String
  serviceType       String
  serviceId         String?
  productId         String?
  packageId         String?
  locationId        String?
  title             String
  date              DateTime
  startTime         String?
  endTime           String?
  capacityTotal     Int
  capacityHeld      Int      @default(0)
  capacityConfirmed Int      @default(0)
  capacityReleased  Int      @default(0)
  status            String   @default("ACTIVE")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledgers           ServiceCapacityLedger[]
  serviceBookings   ServiceBooking[]

  @@index([tenantId, serviceType, date])
  @@index([tenantId, status, date])
}

model ServiceCapacityRule {
  id                   String           @id @default(cuid())
  tenantId             String
  serviceId            String?
  variantId            String?
  locationText         String?
  specificDate         DateTime?
  startDate            DateTime?
  endDate              DateTime?
  dailyLimit           Int?
  weeklyLimit          Int?
  monthlyLimit         Int?
  totalLimit           Int?
  manualReviewFallback Boolean          @default(true)
  active               Boolean          @default(true)
  notes                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service              Product?         @relation("ServiceCapacityRuleService", fields: [serviceId], references: [id], onDelete: Cascade)
  variant              ProductVariant?  @relation("ServiceCapacityRuleVariant", fields: [variantId], references: [id], onDelete: SetNull)
  serviceBookings      ServiceBooking[]

  @@index([tenantId, active])
  @@index([tenantId, serviceId, variantId, active])
  @@index([tenantId, specificDate])
  @@index([tenantId, startDate, endDate])
}

model ServiceCapacityLedger {
  id           String              @id @default(cuid())
  tenantId     String
  slotId       String
  movementType String
  quantity     Int
  sourceType   String
  sourceId     String?
  reason       String
  actorId      String?
  createdAt    DateTime            @default(now())
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slot         ServiceCapacitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  actor        User?               @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, slotId, createdAt])
  @@index([tenantId, sourceType, sourceId])
}

model Assignment {
  id                  String   @id @default(cuid())
  tenantId            String
  workType            String
  workId              String
  assignedRole        String?
  assignedUserId      String?
  assignmentLabel     String?
  status              String   @default("ASSIGNED")
  priority            String   @default("NORMAL")
  dueAt               DateTime?
  internalNote        String?
  customerVisibleNote String?
  createdById         String
  updatedById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedUser        User?    @relation("AssignmentAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy           User     @relation("AssignmentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy           User?    @relation("AssignmentUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([tenantId, workType, workId])
  @@index([tenantId, status, priority])
  @@index([assignedUserId, status])
}

model Tag {
  id          String        @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  type        String
  description String?
  status      String        @default("ACTIVE")
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aliases     TagAlias[]
  relations   TagRelation[]

  @@unique([tenantId, slug])
  @@index([tenantId, type, status, sortOrder])
  @@index([tenantId, status])
}

model TagAlias {
  id        String   @id @default(cuid())
  tenantId  String
  tagId     String
